---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageGrid from '../../components/PageGrid.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = Array.from(tagMap.entries()).sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="标签" description="博客文章标签列表">
  <PageGrid>
    <div>
      <h1 class="text-2xl font-semibold mb-2">标签</h1>
      <p class="text-text-secondary mb-8">共 {tags.length} 个标签，{posts.length} 篇文章</p>

      {tags.length > 0 ? (
        <div class="flex flex-wrap gap-2.5">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="inline-flex items-center gap-1 text-sm text-text-secondary border border-border rounded-full px-3 py-1 no-underline border-b-0 transition-colors hover:text-text hover:border-text">
              <span>{tag}</span>
              <span class="text-xs opacity-70">{count}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-text-secondary italic">还没有任何标签。</p>
      )}
    </div>
  </PageGrid>
</BaseLayout>
