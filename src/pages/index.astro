---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageGrid from '../components/PageGrid.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="我的日志">
  <PageGrid>
    <ul class="list-none p-0 m-0">
      {posts.map(post => {
        const date = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li class="py-6">
            <a href={`/blog/${post.id}`} class="block border-b-0 mb-3 group">
              <time class="block text-sm text-text-secondary mb-2">{date}</time>
              <span class="block text-lg font-medium border-b border-border pb-1.5 mb-2 group-hover:border-text transition-colors">{post.data.title}</span>
            </a>
            {post.data.description && <p class="text-sm text-text-secondary mb-3 leading-relaxed">{post.data.description}</p>}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <a href={`/tags/${encodeURIComponent(tag)}`} class="text-xs text-text-secondary border border-border rounded-full px-1.5 py-0.5 no-underline transition-colors hover:text-text hover:border-text">{tag}</a>
                ))}
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </PageGrid>
</BaseLayout>
