---
import BaseLayout from './BaseLayout.astro';
import PageGrid from '../components/PageGrid.astro';
import DocTree from '../components/DocTree.astro';
import Comments from '../components/Comments.astro';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const { title, pubDate, description, tags } = post.data;
const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={title} description={description}>
  <PageGrid>
    <DocTree slot="left" />

    <article>
      <div class="mb-12">
        <time datetime={pubDate.toISOString()} class="block text-sm text-text-secondary mb-3">{formattedDate}</time>
        <h1 class="text-3xl font-semibold mb-3">{title}</h1>
        {description && <p class="text-lg text-text-secondary mb-3">{description}</p>}
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="text-xs text-text-secondary border border-border rounded-full px-2 py-0.5 no-underline transition-colors hover:text-text hover:border-text">{tag}</a>
            ))}
          </div>
        )}
      </div>
      <div class="text-base leading-relaxed post-body">
        <slot />
      </div>
      <Comments postId={post.id} />
    </article>

    {tocHeadings.length > 0 && (
      <div slot="right" class="text-sm leading-relaxed">
        <div class="font-semibold text-xs text-text-secondary uppercase tracking-wider mb-3">目录</div>
        <ul class="list-none p-0 m-0" id="toc">
          {tocHeadings.map(h => (
            <li class="toc-item mb-2" data-heading-id={h.slug}>
              <a
                href={`#${h.slug}`}
                class:list={[
                  "toc-link flex items-center gap-2 truncate no-underline border-0 text-text-secondary hover:text-text transition-colors",
                  h.depth === 3 && "pl-4"
                ]}
              >
                <span class="toc-dot w-1.5 h-1.5 rounded-full bg-border flex-shrink-0 transition-colors"></span>
                <span class="truncate">{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </PageGrid>

  <script is:inline>
    (function() {
      const tocLinks = document.querySelectorAll('.toc-link');
      const tocItems = document.querySelectorAll('.toc-item');
      if (!tocLinks.length) return;

      const headingMap = new Map();
      tocItems.forEach(item => {
        const id = item.getAttribute('data-heading-id');
        if (id) {
          const heading = document.getElementById(id);
          if (heading) headingMap.set(id, { item, heading });
        }
      });

      function updateActive() {
        const scrollPos = window.scrollY + 100;
        let activeId = null;

        headingMap.forEach(({ heading }, id) => {
          if (heading.offsetTop <= scrollPos) {
            activeId = id;
          }
        });

        tocItems.forEach(item => {
          const dot = item.querySelector('.toc-dot');
          const link = item.querySelector('.toc-link');
          if (item.getAttribute('data-heading-id') === activeId) {
            dot?.classList.remove('bg-border');
            dot?.classList.add('bg-text');
            link?.classList.remove('text-text-secondary');
            link?.classList.add('text-text');
          } else {
            dot?.classList.add('bg-border');
            dot?.classList.remove('bg-text');
            link?.classList.add('text-text-secondary');
            link?.classList.remove('text-text');
          }
        });
      }

      updateActive();
      window.addEventListener('scroll', updateActive, { passive: true });
    })();
  </script>
</BaseLayout>

<style>
  article :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.5rem;
    scroll-margin-top: 1.5rem;
  }

  article :global(h3) {
    font-size: 1.15rem;
    margin-top: 2rem;
    scroll-margin-top: 1.5rem;
  }
</style>
