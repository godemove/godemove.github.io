---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '一个极简主义的个人博客' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script is:inline>
      (function() {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-300.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-400.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-300-italic.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-400-italic.css" />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrapper">
      <header>
        <nav>
          <a href="/" class="site-title">我的日志</a>
          <div class="nav-right">
            <div class="nav-links">
              <a href="/">文章</a>
              <a href="/tags">标签</a>
              <a href="/about">关于</a>
            </div>
            <ThemeToggle />
          </div>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>&copy; {new Date().getFullYear()} 我的日志. 保留所有权利.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .wrapper {
    max-width: 1500px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    margin-bottom: 4rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-title {
    font-weight: 600;
    font-size: 1.1rem;
    border-bottom: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-size: 0.95rem;
    color: var(--text-secondary);
    border-bottom: none;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  main {
    flex: 1;
  }

  footer {
    margin-top: 5rem;
    padding-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: center;
  }
</style>
