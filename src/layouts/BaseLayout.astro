---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '一个极简主义的个人博客' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script is:inline>
      (function() {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-300.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-400.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-300-italic.css" />
    <link rel="stylesheet" href="/fonts/lxgwbrightcode-400-italic.css" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={new URL('rss.xml', Astro.site).toString()} />
    <title>{title}</title>
  </head>
  <body>
    <div class="max-w-[1500px] mx-auto px-6 py-12 min-h-screen flex flex-col">
      <header class="mb-16">
        <nav class="flex justify-between items-center">
          <a href="/" class="font-semibold text-lg no-underline border-0">我的日志</a>
          <div class="flex items-center gap-6">
            <div class="flex items-center gap-6">
              <a href="/tags" class="text-sm text-text-secondary no-underline border-0 hover:text-text transition-colors">标签</a>
              <a href="/about" class="text-sm text-text-secondary no-underline border-0 hover:text-text transition-colors">关于</a>
            </div>
            <ThemeToggle />
          </div>
        </nav>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="mt-20 pt-8 text-sm text-text-secondary flex justify-center items-center gap-4">
        <span>&copy; {new Date().getFullYear()} 我的日志·保留所有权利</span>
        <a href={new URL('rss.xml', Astro.site).toString()} class="rss-link" aria-label="RSS">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="4" cy="20" r="2"></circle>
          </svg>
        </a>
      </footer>
    </div>
  </body>
</html>

<style>
  .rss-link {
    color: var(--text-secondary);
    border-bottom: none;
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .rss-link:hover {
    opacity: 1;
    color: var(--text);
  }
</style>
