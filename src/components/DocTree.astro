---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear = new Map<number, typeof allPosts>();
for (const p of allPosts) {
  const year = new Date(p.data.pubDate).getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(p);
}
const years = Array.from(postsByYear.keys()).sort((a, b) => b - a);

const currentPath = Astro.url.pathname;
---

<div class="text-sm leading-relaxed">
  <div class="font-semibold text-xs text-text-secondary uppercase tracking-wider mb-3">文章</div>
  {years.map(year => (
    <div class="mb-5">
      <div class="text-xs text-text-secondary mb-1">{year}</div>
      <ul class="list-none p-0 m-0">
        {postsByYear.get(year)!.map(p => {
          const postUrl = `/blog/${p.id}`;
          const isCurrent = currentPath === postUrl || currentPath === `${postUrl}/`;
          return (
            <li class="mb-1">
              <a
                href={postUrl}
                class:list={[
                  "block truncate no-underline border-0 transition-colors",
                  isCurrent ? "text-text" : "text-text-secondary hover:text-text"
                ]}
              >
                {p.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</div>
