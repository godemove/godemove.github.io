---
const hasLeft = Astro.slots.has('left');
const hasRight = Astro.slots.has('right');
---

<div class:list={["page-grid", hasLeft && "has-left", hasRight && "has-right"]}>
  {hasLeft && (
    <>
      <aside class="desktop-sidebar">
        <slot name="left" />
      </aside>

      <div id="mobile-sidebar" class="mobile-sidebar" aria-hidden="true">
        <div class="mobile-sidebar-backdrop"></div>
        <div class="mobile-sidebar-panel">
          <div class="mobile-sidebar-header">
            <span class="mobile-sidebar-title">文章列表</span>
            <button type="button" class="mobile-sidebar-close" aria-label="关闭">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
          <slot name="left" />
        </div>
      </div>
    </>
  )}

  <div class="main-content">
    {hasLeft && (
      <button
        type="button"
        class="mobile-sidebar-toggle"
        aria-label="打开文章列表"
        aria-expanded="false"
        aria-controls="mobile-sidebar"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <span class="ml-2">文章</span>
      </button>
    )}
    <slot />
  </div>

  {hasRight && (
    <aside class="desktop-toc">
      <slot name="right" />
    </aside>
  )}
</div>

<script is:inline>
  (function () {
    const toggle = document.querySelector('.mobile-sidebar-toggle');
    const drawer = document.getElementById('mobile-sidebar');
    const closeBtn = drawer?.querySelector('.mobile-sidebar-close');
    const backdrop = drawer?.querySelector('.mobile-sidebar-backdrop');

    function open() {
      drawer?.classList.add('open');
      toggle?.setAttribute('aria-expanded', 'true');
      drawer?.setAttribute('aria-hidden', 'false');
    }

    function close() {
      drawer?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
    }

    toggle?.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
  })();
</script>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas: "main";
    justify-content: center;
    max-width: 1500px;
    margin: 0 auto;
  }

  .main-content {
    grid-area: main;
    min-width: 0;
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .mobile-sidebar-toggle {
    display: inline-flex;
    align-items: center;
    width: 100%;
    margin-bottom: 24px;
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-text-secondary);
    background-color: transparent;
    border: 0.5px solid var(--color-border-tertiary);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .mobile-sidebar-toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-secondary);
  }

  .desktop-sidebar,
  .desktop-toc {
    display: none;
    background-color: var(--color-background-primary);
  }

  .desktop-sidebar {
    border-right: 0.5px solid var(--color-border-tertiary);
  }

  .desktop-toc {
    border-left: 0.5px solid var(--color-border-tertiary);
  }

  .mobile-sidebar {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
    transition: visibility 0.2s ease;
  }

  .mobile-sidebar.open {
    pointer-events: auto;
    visibility: visible;
  }

  .mobile-sidebar-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .mobile-sidebar.open .mobile-sidebar-backdrop {
    opacity: 1;
  }

  .mobile-sidebar-panel {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 260px;
    background-color: var(--color-background-primary);
    border-right: 0.5px solid var(--color-border-tertiary);
    transform: translateX(-100%);
    transition: transform 0.2s ease;
    overflow-y: auto;
  }

  .mobile-sidebar.open .mobile-sidebar-panel {
    transform: translateX(0);
  }

  .mobile-sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }

  .mobile-sidebar-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
  }

  .mobile-sidebar-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--color-text-secondary);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .mobile-sidebar-close:hover {
    color: var(--color-text-primary);
  }

  @media (min-width: 1024px) {
    .page-grid {
      grid-template-columns: 220px minmax(0, 960px) 220px;
      grid-template-areas: "left main right";
      gap: 0;
    }

    .main-content {
      margin: 0;
      padding: 0 48px;
    }

    .mobile-sidebar-toggle,
    .mobile-sidebar {
      display: none;
    }

    .desktop-sidebar,
    .desktop-toc {
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      align-self: start;
      height: calc(100vh - 96px);
      overflow-y: auto;
      overflow-x: hidden;
      background-color: transparent;
    }

    .desktop-sidebar {
      grid-area: left;
      border-right: 0.5px solid var(--color-border-tertiary);
    }

    .desktop-toc {
      grid-area: right;
      border-left: 0.5px solid var(--color-border-tertiary);
    }
  }
</style>
