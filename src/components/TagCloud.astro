---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = Array.from(tagMap.entries()).sort((a, b) => a[0].localeCompare(b[0]));
const currentPath = Astro.url.pathname;
---

<div class="text-sm leading-relaxed">
  <div class="font-semibold text-xs text-text-secondary uppercase tracking-wider mb-3">标签</div>
  {tags.length > 0 ? (
    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => {
        const tagUrl = `/tags/${encodeURIComponent(tag)}`;
        const isCurrent = currentPath === tagUrl || currentPath === `${tagUrl}/`;
        return (
          <a
            href={tagUrl}
            class:list={[
              "inline-flex items-center gap-1 text-xs text-text-secondary border border-border rounded-full px-2 py-0.5 no-underline border-b-0 transition-colors hover:text-text hover:border-text",
              isCurrent && "text-text border-text bg-border"
            ]}
          >
            <span>{tag}</span>
            <span class="text-[10px] opacity-70">{count}</span>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="text-text-secondary text-xs italic">还没有任何标签。</p>
  )}
</div>
